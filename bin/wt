#!/usr/bin/env bash
set -euo pipefail

WT_BIN_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)
WT_ROOT_DIR=$(dirname "$WT_BIN_DIR")

wt_source_module() {
  local module_path
  module_path=$1
  [ -f "$module_path" ] || {
    printf 'wt internal error: missing module: %s\n' "$module_path" >&2
    exit 1
  }
  # shellcheck disable=SC1090
  source "$module_path"
}

wt_source_module "$WT_ROOT_DIR/lib/wt-core.sh"
wt_source_module "$WT_ROOT_DIR/lib/wt-portless.sh"
wt_source_module "$WT_ROOT_DIR/lib/wt-debug.sh"
wt_source_module "$WT_ROOT_DIR/lib/wt-worktree.sh"
wt_source_module "$WT_ROOT_DIR/lib/wt-new.sh"
wt_source_module "$WT_ROOT_DIR/lib/wt-commands.sh"

main() {
  local command
  command=${1-help}
  case "$command" in
    help|--help|-h)
      print_help
      ;;
    new)
      shift
      cmd_new "$@"
      ;;
    init)
      shift
      cmd_init "$@"
      ;;
    b|browse|browser)
      shift
      cmd_b "$@"
      ;;
    cd)
      shift
      cmd_cd "$@"
      ;;
    open)
      shift
      cmd_open "$@"
      ;;
    merge)
      shift
      cmd_merge "$@"
      ;;
    sync)
      shift
      cmd_sync "$@"
      ;;
    rm)
      shift
      cmd_rm "$@"
      ;;
    ls)
      shift
      cmd_ls "$@"
      ;;
    *)
      die "Unknown command: $command (run 'wt --help')"
      ;;
  esac
}

main "$@"
